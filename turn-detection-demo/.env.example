# Turn detection mode: "smart_turn", "flux_semantic", or "vad_only"
TURN_DETECTION_MODE=smart_turn

# Deepgram (STT)
DEEPGRAM_API_KEY=

# Google Gemini (LLM)
GOOGLE_API_KEY=

# Cartesia (TTS)
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=71a7ad14-091c-4e8e-a314-022ece01c121

# Plivo (telephony)
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=

# Tuning — VAD-only mode
VAD_STOP_SECS=0.7          # Fixed silence timeout for VAD-only mode

# Tuning — Smart Turn mode
SMART_TURN_STOP_SECS=3.0   # Max silence before forcing end-of-turn

# Tuning — Deepgram Flux semantic mode
FLUX_EOT_THRESHOLD=0.7     # End-of-turn confidence threshold (lower = faster, more cuts)
FLUX_EOT_TIMEOUT_MS=5000   # Max wait after speech before forcing EOT
# FLUX_EAGER_EOT_THRESHOLD= # Optional: enable eager EOT (lower = more aggressive)

# Dashboard (standalone mode only)
DASHBOARD_PORT=8080

# Railway deployment — set automatically by Railway, or manually for local testing
# RAILWAY_PUBLIC_DOMAIN=your-app.up.railway.app
