# Turn detection mode: "vad_only" or "semantic" (default: semantic)
TURN_DETECTION_MODE=semantic

# Deepgram (STT)
DEEPGRAM_API_KEY=

# Anthropic (LLM)
ANTHROPIC_API_KEY=

# ElevenLabs (TTS)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Plivo (telephony)
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=

# Tuning — silence thresholds
VAD_STOP_SECS=0.7          # Fixed silence timeout for VAD-only mode
SMART_TURN_STOP_SECS=3.0   # Max silence before forcing end-of-turn in semantic mode

# Dashboard
DASHBOARD_PORT=8080
